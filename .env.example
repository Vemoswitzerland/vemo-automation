ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL="file:./prisma/automation.db"

# Instagram Graph API (https://developers.facebook.com/apps/)
INSTAGRAM_ACCESS_TOKEN=<instagram-access-token>
INSTAGRAM_ACCOUNT_ID=<instagram-account-id>
INSTAGRAM_APP_ID=<instagram-app-id>
INSTAGRAM_APP_SECRET=<instagram-app-secret>

# --- Security ---
# API key required on all /api/* routes (x-api-key or Authorization: Bearer)
# Generate with: openssl rand -hex 32
API_SECRET=<generate-with-openssl-rand-hex-32>

# AES-256-GCM key for encrypting stored credentials (email passwords, connector tokens)
# Generate with: openssl rand -hex 32  (must be exactly 64 hex chars = 32 bytes)
ENCRYPTION_KEY=<generate-with-openssl-rand-hex-32>
