# =============================================================
# Vemo Automation Center – Environment Variables Template
# Copy this file to .env.local and fill in your values
# =============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# AI / LLM APIs
# ─────────────────────────────────────────────────────────────

# Anthropic Claude (primary AI)
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (image generation, fallback LLM)
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────

# Local SQLite via Prisma (default for development)
DATABASE_URL="file:./prisma/automation.db"

# ─────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────

# API key required on all /api/* routes (x-api-key or Authorization: Bearer)
# Generate with: openssl rand -hex 32
API_SECRET=<generate-with-openssl-rand-hex-32>
AUTOMATION_API_KEY=<generate-with-openssl-rand-hex-32>

# AES-256-GCM key for encrypting stored credentials (email passwords, connector tokens)
# Generate with: openssl rand -hex 32  (must be exactly 64 hex chars = 32 bytes)
ENCRYPTION_KEY=<generate-with-openssl-rand-hex-32>

# ─────────────────────────────────────────────────────────────
# Instagram / Meta
# ─────────────────────────────────────────────────────────────

# Instagram Graph API
# Create app at: https://developers.facebook.com/apps/
# Required permissions: instagram_basic, instagram_content_publish, pages_read_engagement
INSTAGRAM_ACCESS_TOKEN=<instagram-long-lived-access-token>
INSTAGRAM_ACCOUNT_ID=<instagram-business-account-id>
INSTAGRAM_APP_ID=<meta-app-id>
INSTAGRAM_APP_SECRET=<meta-app-secret>

# ─────────────────────────────────────────────────────────────
# WhatsApp Business
# ─────────────────────────────────────────────────────────────

# WhatsApp Business Cloud API (Meta)
# Get at: https://developers.facebook.com/apps/ (same Meta app, add WhatsApp product)
WHATSAPP_API_TOKEN=<whatsapp-permanent-access-token>
WHATSAPP_PHONE_NUMBER_ID=<whatsapp-phone-number-id>
WHATSAPP_BUSINESS_ACCOUNT_ID=<whatsapp-business-account-id>
WHATSAPP_WEBHOOK_VERIFY_TOKEN=<generate-with-openssl-rand-hex-16>

# ─────────────────────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────────────────────

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
# Default chat/group ID for notifications (get via @userinfobot)
TELEGRAM_CHAT_ID=<telegram-chat-id>
# Webhook secret for verifying Telegram webhook calls
TELEGRAM_WEBHOOK_SECRET=<generate-with-openssl-rand-hex-32>

# ─────────────────────────────────────────────────────────────
# E-Mail (Gmail)
# ─────────────────────────────────────────────────────────────

# Gmail OAuth 2.0 (recommended)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:3000/api/gmail/callback
GMAIL_CLIENT_ID=<google-oauth-client-id>
GMAIL_CLIENT_SECRET=<google-oauth-client-secret>

# Gmail App Password (fallback, simpler setup)
# Enable at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=<gmail-app-password>

# Gmail IMAP/SMTP config (usually no change needed)
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587

# ─────────────────────────────────────────────────────────────
# LinkedIn (planned)
# ─────────────────────────────────────────────────────────────

# LinkedIn API
# Create app at: https://www.linkedin.com/developers/apps
# Required: r_liteprofile, w_member_social, r_organization_social
LINKEDIN_CLIENT_ID=<linkedin-client-id>
LINKEDIN_CLIENT_SECRET=<linkedin-client-secret>
LINKEDIN_ACCESS_TOKEN=<linkedin-access-token>
LINKEDIN_ORGANIZATION_ID=<linkedin-organization-id>

# ─────────────────────────────────────────────────────────────
# Facebook (planned)
# ─────────────────────────────────────────────────────────────

# Facebook Pages API (via Meta developer app)
FACEBOOK_PAGE_ID=<facebook-page-id>
FACEBOOK_PAGE_ACCESS_TOKEN=<facebook-page-access-token>

# ─────────────────────────────────────────────────────────────
# Image Generation (planned)
# ─────────────────────────────────────────────────────────────

# Stable Diffusion (local ComfyUI / Automatic1111)
STABLE_DIFFUSION_API_URL=http://127.0.0.1:7860
# OR: Replicate (cloud SD)
REPLICATE_API_TOKEN=<replicate-api-token>

# ─────────────────────────────────────────────────────────────
# Video Generation (planned)
# ─────────────────────────────────────────────────────────────

# Runway ML
RUNWAY_API_KEY=<runway-api-key>

# ─────────────────────────────────────────────────────────────
# Monitoring & Logging
# ─────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error
LOG_LEVEL=info
# Optional: send structured logs to an external sink (e.g. Logtail, Axiom)
LOG_SINK_URL=
LOG_SINK_TOKEN=

# Optional: Sentry for error tracking
SENTRY_DSN=
