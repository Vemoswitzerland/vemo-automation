generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./automation.db"
}

model Email {
  id             String        @id @default(cuid())
  userId         String        @default("admin")
  uid            String        @unique
  messageId      String?
  from           String
  fromName       String?
  to             String
  subject        String
  body           String
  bodyHtml       String?
  receivedAt     DateTime
  isRead         Boolean       @default(false)
  priority       Int           @default(0)
  labels         String        @default("[]")
  emailAccountId String?
  emailAccount   EmailAccount? @relation(fields: [emailAccountId], references: [id])

  drafts         EmailDraft[]
  attachments    EmailAttachment[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model EmailDraft {
  id          String   @id @default(cuid())
  emailId     String
  email       Email    @relation(fields: [emailId], references: [id])
  subject     String
  body        String
  status      String   @default("pending") // pending | approved | rejected | sent
  aiModel     String   @default("claude-sonnet-4-6")
  aiPrompt    String?

  approvedAt  DateTime?
  sentAt      DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailAccount {
  id               String   @id @default(cuid())
  userId           String   @default("admin")
  name             String
  email            String
  imapHost         String
  imapPort         Int      @default(993)
  smtpHost         String
  smtpPort         Int      @default(587)
  username         String
  password         String   // encrypted; for OAuth accounts: empty string
  isActive         Boolean  @default(true)
  lastSyncAt       DateTime?

  // OAuth2 fields (Gmail OAuth — optional, overrides password when set)
  authType         String   @default("password") // "password" | "oauth2"
  oauthAccessToken  String?  // encrypted access token
  oauthRefreshToken String?  // encrypted refresh token
  oauthExpiry      DateTime? // when access token expires

  // Gmail push notification (Pub/Sub) fields
  gmailHistoryId   String?  // last Gmail historyId processed
  gmailWatchExpiry DateTime? // when the Gmail watch expires (renew before this)

  emails      Email[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailAttachment {
  id          String   @id @default(cuid())
  emailId     String
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  filename    String
  contentType String
  size        Int      // bytes
  contentId   String?  // for inline attachments (CID)
  data        String?  // base64-encoded, only for small attachments (<100KB)

  createdAt   DateTime @default(now())
}

model AppSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  updatedAt   DateTime @updatedAt
}

model Connector {
  id           String    @id
  userId       String    @default("admin") // owner who configured this connector
  status       String    @default("disconnected") // connected | disconnected | error | pending
  credentials  String?   // JSON: encrypted key-value pairs
  lastTestedAt DateTime?
  errorMessage String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model InstagramPost {
  id           String   @id @default(cuid())
  userId       String   @default("admin")
  caption      String
  imageUrl     String?
  imagePrompt  String?
  videoUrl     String?
  videoConcept String?
  script       String?
  status       String   @default("draft") // draft | scheduled | posted | failed
  scheduledAt  DateTime?
  postedAt     DateTime?
  postId       String?  // Instagram post ID after publishing

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Instagram Content Pipeline ───────────────────────────────────────────────
model ContentBrief {
  id          String   @id @default(cuid())
  userId      String   @default("admin")
  name        String   // template name
  thema       String   // content topic / brief
  zielgruppe  String?  // target audience
  hashtags    String?  // comma-separated hashtags
  toneOfVoice String   @default("casual") // casual | professional | motivational
  isTemplate  Boolean  @default(false)    // saved as reusable template

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FacebookPost {
  id          String    @id @default(cuid())
  userId      String    @default("admin")
  caption     String
  imageUrl    String?
  imagePrompt String?
  status      String    @default("draft") // draft | scheduled | posted | failed
  scheduledAt DateTime?
  postedAt    DateTime?
  postId      String?   // Facebook post ID after publishing

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model LinkedInPost {
  id          String    @id @default(cuid())
  userId      String    @default("admin")
  caption     String
  imageUrl    String?
  imagePrompt String?
  status      String    @default("draft") // draft | scheduled | posted | failed
  scheduledAt DateTime?
  postedAt    DateTime?
  postId      String?   // LinkedIn post URN after publishing

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WhatsAppCustomer {
  id            String    @id @default(cuid())
  phone         String    @unique  // E.164 normalized (+41791234567)
  name          String?
  email         String?
  tags          String    @default("[]")  // JSON: ["hot-lead", "vip", ...]
  notes         String?
  crmLeadId     String?   // Link to Lead.id
  messageCount  Int       @default(0)
  lastContactAt DateTime?

  messages      WhatsAppMessage[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model WhatsAppMessage {
  id         String   @id @default(cuid())
  userId     String   @default("admin")
  waId       String   @unique // WhatsApp message ID (mock or real)
  from       String   // Phone number or contact name
  fromName   String?
  body       String
  mediaUrl   String?  // Image/video/audio if any
  direction  String   @default("inbound") // inbound | outbound
  status     String   @default("unread") // unread | read | archived
  receivedAt DateTime

  customerId String?
  customer   WhatsAppCustomer? @relation(fields: [customerId], references: [id])

  drafts     WhatsAppDraft[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WhatsAppDraft {
  id         String          @id @default(cuid())
  messageId  String
  message    WhatsAppMessage @relation(fields: [messageId], references: [id])
  body       String
  status     String          @default("pending") // pending | approved | rejected | sent
  aiModel    String          @default("claude-sonnet-4-6")
  aiPrompt   String?

  approvedAt DateTime?
  sentAt     DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Flow {
  id          String   @id @default(cuid())
  userId      String   @default("admin")
  name        String   @default("Unbenannter Flow")
  description String?
  status      String   @default("draft") // draft | active | paused | archived
  nodes       String   @default("[]") // JSON: ReactFlow nodes array
  edges       String   @default("[]") // JSON: ReactFlow edges array
  version     Int      @default(1)
  deployedAt  DateTime?
  boardId     String?  // optional: associated board

  board       Board?   @relation(fields: [boardId], references: [id])
  executions  Execution[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Board {
  id          String        @id @default(cuid())
  name        String        @default("Mein Board")
  description String?

  members     BoardMember[]
  flows       Flow[]
  executions  Execution[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BoardMember {
  id        String   @id @default(cuid())
  boardId   String
  userId    String   // references user by string ID
  role      String   @default("owner") // owner | collaborator

  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([boardId, userId])
}

model Execution {
  id          String    @id @default(cuid())
  flowId      String
  boardId     String?
  triggeredBy String?   // userId who triggered
  status      String    @default("pending") // pending | running | success | failed
  input       String?   // JSON: input parameters
  output      String?   // JSON: result output
  error       String?   // error message if failed
  isTest      Boolean   @default(false)
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  flow        Flow      @relation(fields: [flowId], references: [id])
  board       Board?    @relation(fields: [boardId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Approval {
  id          String   @id @default(cuid())
  userId      String   @default("admin")
  title       String
  description String?
  status      String   @default("pending") // pending | approved | rejected | expired
  channel     String   @default("telegram") // telegram | manual
  chatId      String?  // Telegram chat_id where message was sent
  messageId   String?  // Telegram message_id (for editing)
  metadata    String?  // JSON: extra context

  approvedAt  DateTime?
  rejectedAt  DateTime?
  expiresAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── API-Stub: Lead Management ─────────────────────────────────────────────────
// Ready for CRM / Lead API integration (HubSpot, Pipedrive, custom)
model Lead {
  id          String   @id @default(cuid())
  userId      String   @default("admin")
  name        String
  email       String?
  phone       String?
  source      String   @default("unknown") // instagram | facebook | google_ads | referral | manual
  status      String   @default("new")     // new | qualified | contacted | converted | lost
  notes       String?
  value       Float?   // estimated deal value in CHF

  // API stub fields — populated once real CRM API is connected
  externalId  String?  // CRM record ID
  syncedAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── WhatsApp Bot Intent Logging ──────────────────────────────────────────────
model WhatsAppBotLog {
  id          String   @id @default(cuid())
  userId      String   @default("admin")
  messageId   String?  // WhatsAppMessage id (optional, may not exist if webhook)
  from        String   // Phone number of sender
  fromName    String?
  messageBody String   // Original inbound message
  intent      String   // classified intent: product_info | price | delivery | support | appointment | off_topic
  confidence  Float    // 0.0 – 1.0
  handledBy   String   // "bot" | "agent"
  botResponse String?  // Response sent by bot (if handledBy = bot)
  templateKey String?  // Which template was used
  createdAt   DateTime @default(now())
}

// ── Ads A/B Testing & Auto-Scaling ───────────────────────────────────────────
model AdsAbTest {
  id              String           @id @default(cuid())
  userId          String           @default("admin")
  name            String
  campaignId      String?          // optional: linked AdsCampaign
  status          String           @default("running") // running | completed | paused
  trafficSplit    Float            @default(0.5)        // 0.0–1.0 share for variant A
  winnerVariantId String?
  autoScaling     Boolean          @default(true)       // false = manual override
  evaluatedAt     DateTime?
  completedAt     DateTime?

  variants        AdsAbTestVariant[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AdsAbTestVariant {
  id          String     @id @default(cuid())
  testId      String
  test        AdsAbTest  @relation(fields: [testId], references: [id], onDelete: Cascade)
  label       String     // "A" | "B" | custom
  adId        String?    // external ad / campaign variant ID
  spend       Float      @default(0)
  revenue     Float      @default(0)    // used for ROAS calculation
  impressions Int        @default(0)
  clicks      Int        @default(0)
  conversions Int        @default(0)
  budget      Float      @default(0)
  status      String     @default("active") // active | paused | winner | loser

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ── Ads Audit Trail ──────────────────────────────────────────────────────────
model AdsAuditLog {
  id          String   @id @default(cuid())
  userId      String   @default("admin")
  entity      String   // "campaign" | "ab_test" | "variant"
  entityId    String
  action      String   // "budget_scaled" | "budget_reduced" | "paused" | "winner_detected" | "manual_override"
  before      String?  // JSON snapshot before
  after       String?  // JSON snapshot after
  reason      String?
  triggeredBy String   @default("system") // "system" | "cron" | "user"

  createdAt   DateTime @default(now())
}

// ── E-Mail Automation ────────────────────────────────────────────────────────
model AutomationRule {
  id           String   @id @default(cuid())
  userId       String   @default("admin")
  name         String
  description  String?
  isActive     Boolean  @default(true)
  priority     Int      @default(0)   // lower number = higher priority

  // Trigger
  triggerType  String   // "category" | "keyword" | "sender" | "subject"
  triggerValue String
  matchMode    String   @default("contains") // "contains" | "equals" | "startsWith" | "regex"

  // Action
  actionType     String   // "auto_reply" | "queue" | "label"
  replyTemplate  String?  // reply body template (for auto_reply)
  replySubject   String?  // reply subject (for auto_reply)
  labelValue     String?  // label to add (for label action)

  // Stats
  triggerCount    Int       @default(0)
  lastTriggeredAt DateTime?

  logs  AutomationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AutomationLog {
  id             String          @id @default(cuid())
  emailId        String
  ruleId         String?
  rule           AutomationRule? @relation(fields: [ruleId], references: [id])

  action         String   // "auto_replied" | "queued" | "labelled" | "fallback"
  wasAutoReplied Boolean  @default(false)
  responseTimeMs Int?     // ms from email.receivedAt to reply sent

  emailFrom      String
  emailSubject   String
  matchedRule    String?  // rule name snapshot for audit trail
  replyPreview   String?  // first 300 chars of sent reply

  createdAt DateTime @default(now())
}

// ── API-Stub: Ads Campaign Tracking ──────────────────────────────────────────
// Ready for Meta Ads / Google Ads API integration
model AdsCampaign {
  id          String   @id @default(cuid())
  userId      String   @default("admin")
  name        String
  platform    String   @default("meta") // meta | google | tiktok | linkedin
  status      String   @default("active") // active | paused | ended | draft
  budget      Float    @default(0)    // daily/total budget in CHF
  spend       Float    @default(0)    // actual spend
  reach       Int      @default(0)
  clicks      Int      @default(0)
  leads       Int      @default(0)
  startDate   DateTime?
  endDate     DateTime?

  // API stub fields — populated once real Ads API is connected
  externalId  String?  // Platform campaign ID
  syncedAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
