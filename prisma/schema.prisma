generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./automation.db"
}

model Email {
  id             String        @id @default(cuid())
  uid            String        @unique
  messageId      String?
  from           String
  fromName       String?
  to             String
  subject        String
  body           String
  bodyHtml       String?
  receivedAt     DateTime
  isRead         Boolean       @default(false)
  priority       Int           @default(0)
  labels         String        @default("[]")
  emailAccountId String?
  emailAccount   EmailAccount? @relation(fields: [emailAccountId], references: [id])

  drafts         EmailDraft[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model EmailDraft {
  id          String   @id @default(cuid())
  emailId     String
  email       Email    @relation(fields: [emailId], references: [id])
  subject     String
  body        String
  status      String   @default("pending") // pending | approved | rejected | sent
  aiModel     String   @default("claude-sonnet-4-6")
  aiPrompt    String?

  approvedAt  DateTime?
  sentAt      DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailAccount {
  id          String   @id @default(cuid())
  name        String
  email       String
  imapHost    String
  imapPort    Int      @default(993)
  smtpHost    String
  smtpPort    Int      @default(587)
  username    String
  password    String   // In production: encrypt this
  isActive    Boolean  @default(true)
  lastSyncAt  DateTime?

  emails      Email[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  updatedAt   DateTime @updatedAt
}

model Connector {
  id           String    @id
  status       String    @default("disconnected") // connected | disconnected | error | pending
  credentials  String?   // JSON: encrypted key-value pairs
  lastTestedAt DateTime?
  errorMessage String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model InstagramPost {
  id          String   @id @default(cuid())
  caption     String
  imageUrl    String?
  imagePrompt String?
  videoUrl      String?
  videoConcept  String?
  script        String?
  status        String   @default("draft") // draft | scheduled | posted | failed
  scheduledAt DateTime?
  postedAt    DateTime?
  postId      String?  // Instagram post ID after publishing

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FacebookPost {
  id          String    @id @default(cuid())
  caption     String
  imageUrl    String?
  imagePrompt String?
  status      String    @default("draft") // draft | scheduled | posted | failed
  scheduledAt DateTime?
  postedAt    DateTime?
  postId      String?   // Facebook post ID after publishing

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model LinkedInPost {
  id          String    @id @default(cuid())
  caption     String
  imageUrl    String?
  imagePrompt String?
  status      String    @default("draft") // draft | scheduled | posted | failed
  scheduledAt DateTime?
  postedAt    DateTime?
  postId      String?   // LinkedIn post URN after publishing

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  waId        String   @unique // WhatsApp message ID (mock or real)
  from        String   // Phone number or contact name
  fromName    String?
  body        String
  mediaUrl    String?  // Image/video/audio if any
  direction   String   @default("inbound") // inbound | outbound
  status      String   @default("unread") // unread | read | archived
  receivedAt  DateTime

  drafts      WhatsAppDraft[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WhatsAppDraft {
  id         String          @id @default(cuid())
  messageId  String
  message    WhatsAppMessage @relation(fields: [messageId], references: [id])
  body       String
  status     String          @default("pending") // pending | approved | rejected | sent
  aiModel    String          @default("claude-sonnet-4-6")
  aiPrompt   String?

  approvedAt DateTime?
  sentAt     DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Flow {
  id          String   @id @default(cuid())
  name        String   @default("Unbenannter Flow")
  description String?
  status      String   @default("draft") // draft | active | paused | archived
  nodes       String   @default("[]") // JSON: ReactFlow nodes array
  edges       String   @default("[]") // JSON: ReactFlow edges array
  version     Int      @default(1)
  deployedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Approval {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending") // pending | approved | rejected | expired
  channel     String   @default("telegram") // telegram | manual
  chatId      String?  // Telegram chat_id where message was sent
  messageId   String?  // Telegram message_id (for editing)
  metadata    String?  // JSON: extra context

  approvedAt  DateTime?
  rejectedAt  DateTime?
  expiresAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── API-Stub: Lead Management ─────────────────────────────────────────────────
// Ready for CRM / Lead API integration (HubSpot, Pipedrive, custom)
model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  source      String   @default("unknown") // instagram | facebook | google_ads | referral | manual
  status      String   @default("new")     // new | qualified | contacted | converted | lost
  notes       String?
  value       Float?   // estimated deal value in CHF

  // API stub fields — populated once real CRM API is connected
  externalId  String?  // CRM record ID
  syncedAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── API-Stub: Ads Campaign Tracking ──────────────────────────────────────────
// Ready for Meta Ads / Google Ads API integration
model AdsCampaign {
  id          String   @id @default(cuid())
  name        String
  platform    String   @default("meta") // meta | google | tiktok | linkedin
  status      String   @default("active") // active | paused | ended | draft
  budget      Float    @default(0)    // daily/total budget in CHF
  spend       Float    @default(0)    // actual spend
  reach       Int      @default(0)
  clicks      Int      @default(0)
  leads       Int      @default(0)
  startDate   DateTime?
  endDate     DateTime?

  // API stub fields — populated once real Ads API is connected
  externalId  String?  // Platform campaign ID
  syncedAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
